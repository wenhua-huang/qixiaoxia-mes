            #{transactionId}
        </foreach>
    </delete>

    <!-- 幂等检查：同一来源单据 + 同一行 + 同一事务类型 已存在则返回已有记录 -->
    <select id="selectExistingTransaction" parameterType="WmTransaction" resultMap="WmTransactionResult">
        <include refid="selectWmTransactionVo"/>
        where source_doc_type = #{sourceDocType}
          and source_doc_id = #{sourceDocId}
          and source_line_id = #{sourceLineId}
          and transaction_type = #{transactionType}
        limit 1
