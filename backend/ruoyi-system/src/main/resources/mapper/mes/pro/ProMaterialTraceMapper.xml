    <update id="updateProMaterialTrace" parameterType="ProMaterialTrace">
        update qxx_pro_material_trace
        <trim prefix="SET" suffixOverrides=",">
            <if test="traceType != null and traceType != ''">trace_type = #{traceType},</if>
            <if test="parentType != null and parentType != ''">parent_type = #{parentType},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="childType != null and childType != ''">child_type = #{childType},</if>
            <if test="childId != null">child_id = #{childId},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''">unit_of_measure = #{unitOfMeasure},</if>
            <if test="workorderId != null">workorder_id = #{workorderId},</if>
            <if test="cardId != null">card_id = #{cardId},</if>
            <if test="cardProcessId != null">card_process_id = #{cardProcessId},</if>
            <if test="issueId != null">issue_id = #{issueId},</if>
            <if test="issueDetailId != null">issue_detail_id = #{issueDetailId},</if>
            <if test="feedbackId != null">feedback_id = #{feedbackId},</if>
            <if test="transactionId != null">transaction_id = #{transactionId},</if>
            <if test="processId != null">process_id = #{processId},</if>
            <if test="traceTime != null">trace_time = #{traceTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where trace_id = #{traceId}
    </update>

    <delete id="deleteProMaterialTraceByTraceId" parameterType="Long">
        delete from qxx_pro_material_trace where trace_id = #{traceId}
    </delete>

    <delete id="deleteProMaterialTraceByTraceIds">
        delete from qxx_pro_material_trace where trace_id in
        <foreach item="traceId" collection="array" open="(" separator="," close=")">
            #{traceId}
        </foreach>
    </delete>

    <select id="selectByParent" resultMap="ProMaterialTraceResult">
        <include refid="selectProMaterialTraceVo"/>
        where parent_type = #{parentType} and parent_id = #{parentId}
        order by trace_time asc
    </select>

    <select id="selectByChild" resultMap="ProMaterialTraceResult">
        <include refid="selectProMaterialTraceVo"/>
        where child_type = #{childType} and child_id = #{childId}
