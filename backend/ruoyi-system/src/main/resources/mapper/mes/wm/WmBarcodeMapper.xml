    <sql id="selectWmBarcodeVo">
        select barcode_id, factory_id, barcode_code, barcode_type, item_id, item_code, item_name, workorder_id, workorder_code, quantity, unit_of_measure, batch_code, print_count, last_print_time, enable_flag, remark, create_by, create_time, update_by, update_time from qxx_wm_barcode
    </sql>

    <select id="selectWmBarcodeList" parameterType="WmBarcode" resultMap="WmBarcodeResult">
        <include refid="selectWmBarcodeVo"/>
        <where>
            <if test="factoryId != null"> and factory_id = #{factoryId}</if>
            <if test="barcodeCode != null and barcodeCode != ''"> and barcode_code like concat('%', #{barcodeCode}, '%')</if>
            <if test="barcodeType != null and barcodeType != ''"> and barcode_type like concat('%', #{barcodeType}, '%')</if>
            <if test="itemId != null"> and item_id = #{itemId}</if>
            <if test="itemCode != null and itemCode != ''"> and item_code like concat('%', #{itemCode}, '%')</if>
            <if test="itemName != null and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="workorderId != null"> and workorder_id = #{workorderId}</if>
            <if test="workorderCode != null and workorderCode != ''"> and workorder_code like concat('%', #{workorderCode}, '%')</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''"> and unit_of_measure like concat('%', #{unitOfMeasure}, '%')</if>
            <if test="batchCode != null and batchCode != ''"> and batch_code like concat('%', #{batchCode}, '%')</if>
            <if test="printCount != null"> and print_count = #{printCount}</if>
            <if test="enableFlag != null and enableFlag != ''"> and enable_flag like concat('%', #{enableFlag}, '%')</if>
            <if test="createBy != null and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="updateBy != null and updateBy != ''"> and update_by like concat('%', #{updateBy}, '%')</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectWmBarcodeAll" resultMap="WmBarcodeResult">
        <include refid="selectWmBarcodeVo"/>
    </select>

    <select id="selectWmBarcodeByBarcodeId" parameterType="Long" resultMap="WmBarcodeResult">
        <include refid="selectWmBarcodeVo"/>
        where barcode_id = #{barcodeId}
    </select>

    <insert id="insertWmBarcode" parameterType="WmBarcode" useGeneratedKeys="true" keyProperty="barcodeId">
        insert into qxx_wm_barcode
        <trim prefix="(" suffix=")" suffixOverrides=",">
