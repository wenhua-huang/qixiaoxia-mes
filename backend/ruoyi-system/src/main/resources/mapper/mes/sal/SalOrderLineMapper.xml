    <sql id="selectSalOrderLineVo">
        select line_id, factory_id, order_id, line_no, product_id, product_code, product_name, product_spc, unit_of_measure, unit_name, quantity, unit_price, line_amount, spacing, product_size, printing_req, rope_spec, package_req, shipping_req, request_date, remark, create_by, create_time, update_by, update_time from qxx_sal_order_line
    </sql>

    <select id="selectSalOrderLineByLineId" parameterType="Long" resultMap="SalOrderLineResult">
        <include refid="selectSalOrderLineVo"/>
        where line_id = #{lineId}
    </select>

    <select id="selectSalOrderLineByOrderId" parameterType="Long" resultMap="SalOrderLineResult">
        <include refid="selectSalOrderLineVo"/>
        where order_id = #{orderId}
        order by line_no
    </select>

    <insert id="insertSalOrderLine" parameterType="SalOrderLine" useGeneratedKeys="true" keyProperty="lineId">
        insert into qxx_sal_order_line
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null">order_id,</if>
            <if test="lineNo != null">line_no,</if>
            <if test="productId != null">product_id,</if>
            <if test="productCode != null">product_code,</if>
            <if test="productName != null">product_name,</if>
            <if test="productSpc != null">product_spc,</if>
            <if test="unitOfMeasure != null">unit_of_measure,</if>
            <if test="unitName != null">unit_name,</if>
            <if test="quantity != null">quantity,</if>
            <if test="unitPrice != null">unit_price,</if>
            <if test="lineAmount != null">line_amount,</if>
            <if test="spacing != null">spacing,</if>
            <if test="productSize != null">product_size,</if>
            <if test="printingReq != null">printing_req,</if>
            <if test="ropeSpec != null">rope_spec,</if>
            <if test="packageReq != null">package_req,</if>
            <if test="shippingReq != null">shipping_req,</if>
            <if test="requestDate != null">request_date,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null">#{orderId},</if>
            <if test="lineNo != null">#{lineNo},</if>
            <if test="productId != null">#{productId},</if>
            <if test="productCode != null">#{productCode},</if>
            <if test="productName != null">#{productName},</if>
            <if test="productSpc != null">#{productSpc},</if>
            <if test="unitOfMeasure != null">#{unitOfMeasure},</if>
            <if test="unitName != null">#{unitName},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="unitPrice != null">#{unitPrice},</if>
            <if test="lineAmount != null">#{lineAmount},</if>
            <if test="spacing != null">#{spacing},</if>
            <if test="productSize != null">#{productSize},</if>
            <if test="printingReq != null">#{printingReq},</if>
            <if test="ropeSpec != null">#{ropeSpec},</if>
