<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.mes.pro.ProSnapshotMapper">
    <resultMap type="ProSnapshot" id="ProSnapshotResult">
        <result property="id" column="id"/>
        <result property="factoryId" column="factory_id"/>
        <result property="name" column="name"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeId" column="scope_id"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectVo">select id, factory_id, name, scope_type, scope_id, status, remark, create_by, create_time, update_by, update_time from qxx_pro_snapshot</sql>

    <select id="selectProSnapshotById" resultMap="ProSnapshotResult"><include refid="selectVo"/> where id = #{id}</select>

    <select id="selectProSnapshotList" parameterType="ProSnapshot" resultMap="ProSnapshotResult">
        <include refid="selectVo"/>
        <where>
            <if test="factoryId != null">and factory_id = #{factoryId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
            <if test="name != null and name != ''">and name like concat('%',#{name},'%')</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertProSnapshot" useGeneratedKeys="true" keyProperty="id">
        insert into qxx_pro_snapshot
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="scopeType != null">scope_type,</if>
            <if test="scopeId != null">scope_id,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="scopeType != null">#{scopeType},</if>
            <if test="scopeId != null">#{scopeId},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateProSnapshot">
        update qxx_pro_snapshot
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteProSnapshotById">delete from qxx_pro_snapshot where id = #{id}</delete>
    <delete id="deleteProSnapshotByIds">delete from qxx_pro_snapshot where id in <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
