<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.mes.md.MdWorkstationMapper">

    <resultMap type="com.ruoyi.system.domain.mes.md.MdWorkstation" id="MdWorkstationResult">
        <result property="workstationId"    column="workstation_id"     />
        <result property="factoryId"        column="factory_id"         />
        <result property="workstationCode"  column="workstation_code"   />
        <result property="workstationName"  column="workstation_name"   />
        <result property="workshopId"       column="workshop_id"        />
        <result property="workstationType"  column="workstation_type"   />
        <result property="processId"        column="process_id"         />
        <result property="processType"      column="process_type"       />
        <result property="processName"      column="process_name"       />
        <result property="capacity"         column="capacity"           />
        <result property="status"           column="status"             />
        <result property="enableFlag"       column="enable_flag"        />
        <result property="remark"           column="remark"             />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
    </resultMap>

    <sql id="selectMdWorkstationVo">
        select w.workstation_id, w.factory_id, w.workstation_code, w.workstation_name,
               w.workshop_id, w.workstation_type, w.process_id, w.process_type,
               p.process_name, w.capacity, w.status,
               w.enable_flag, w.remark, w.create_by, w.create_time, w.update_by, w.update_time
        from qxx_md_workstation w
        left join qxx_pro_process p on w.process_id = p.process_id
    </sql>

    <select id="selectMdWorkstationList" parameterType="com.ruoyi.system.domain.mes.md.MdWorkstation" resultMap="MdWorkstationResult">
        <include refid="selectMdWorkstationVo"/>
        <where>
            <if test="workstationCode != null  and workstationCode != ''"> and workstation_code = #{workstationCode}</if>
            <if test="workstationName != null  and workstationName != ''"> and workstation_name like concat('%', #{workstationName}, '%')</if>
            <if test="workshopId != null"> and workshop_id = #{workshopId}</if>
            <if test="workstationType != null  and workstationType != ''"> and workstation_type = #{workstationType}</if>
            <if test="processId != null"> and w.process_id = #{processId}</if>
            <if test="processType != null  and processType != ''"> and w.process_type = #{processType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="enableFlag != null  and enableFlag != ''"> and w.enable_flag = #{enableFlag}</if>
        </where>
    </select>

    <select id="checkWorkstationCodeUnique" parameterType="com.ruoyi.system.domain.mes.md.MdWorkstation" resultMap="MdWorkstationResult">
        <include refid="selectMdWorkstationVo"/>
        where workstation_code = #{workstationCode} limit 1
    </select>

    <select id="selectMdWorkstationByWorkstationId" parameterType="Long" resultMap="MdWorkstationResult">
        <include refid="selectMdWorkstationVo"/>
        where workstation_id = #{workstationId}
    </select>

    <insert id="insertMdWorkstation" parameterType="com.ruoyi.system.domain.mes.md.MdWorkstation" useGeneratedKeys="true" keyProperty="workstationId">
        insert into qxx_md_workstation
        <trim prefix="(" suffix=")" suffixOverrides=",">            <if test="workstationCode != null and workstationCode != ''">workstation_code,</if>
            <if test="workstationName != null and workstationName != ''">workstation_name,</if>
            <if test="workshopId != null">workshop_id,</if>
            <if test="workstationType != null">workstation_type,</if>
            <if test="processId != null">process_id,</if>
            <if test="processType != null">process_type,</if>
            <if test="capacity != null">capacity,</if>
            <if test="status != null">status,</if>
            <if test="enableFlag != null and enableFlag != ''">enable_flag,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">            <if test="workstationCode != null and workstationCode != ''">#{workstationCode},</if>
            <if test="workstationName != null and workstationName != ''">#{workstationName},</if>
            <if test="workshopId != null">#{workshopId},</if>
            <if test="workstationType != null">#{workstationType},</if>
            <if test="processId != null">#{processId},</if>
            <if test="processType != null">#{processType},</if>
            <if test="capacity != null">#{capacity},</if>
            <if test="status != null">#{status},</if>
            <if test="enableFlag != null and enableFlag != ''">#{enableFlag},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateMdWorkstation" parameterType="com.ruoyi.system.domain.mes.md.MdWorkstation">
        update qxx_md_workstation
        <trim prefix="SET" suffixOverrides=",">            <if test="workstationCode != null and workstationCode != ''">workstation_code = #{workstationCode},</if>
            <if test="workstationName != null and workstationName != ''">workstation_name = #{workstationName},</if>
            <if test="workshopId != null">workshop_id = #{workshopId},</if>
            <if test="workstationType != null">workstation_type = #{workstationType},</if>
            <if test="processId != null">process_id = #{processId},</if>
            <if test="processType != null">process_type = #{processType},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="status != null">status = #{status},</if>
            <if test="enableFlag != null and enableFlag != ''">enable_flag = #{enableFlag},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where workstation_id = #{workstationId}
    </update>

    <delete id="deleteMdWorkstationByWorkstationId" parameterType="Long">
        delete from qxx_md_workstation where workstation_id = #{workstationId}
    </delete>

    <delete id="deleteMdWorkstationByWorkstationIds" parameterType="String">
        delete from qxx_md_workstation where workstation_id in
        <foreach item="workstationId" collection="array" open="(" separator="," close=")">
            #{workstationId}
        </foreach>
    </delete>
</mapper>
