    <sql id="selectWmRtIssueVo">
        select rt_id, factory_id, rt_code, rt_name, issue_id, issue_code, workorder_id, workorder_code, workorder_name, workstation_id, workstation_code, workstation_name, warehouse_id, warehouse_code, warehouse_name, rt_date, total_quantity, unit_of_measure, unit_name, rqc_id, rqc_code, status, remark, create_by, create_time, update_by, update_time from qxx_wm_rt_issue
    </sql>

    <select id="selectWmRtIssueList" parameterType="WmRtIssue" resultMap="WmRtIssueResult">
        <include refid="selectWmRtIssueVo"/>
        <where>
            <if test="rtCode != null  and rtCode != ''"> and rt_code = #{rtCode}</if>
            <if test="workorderId != null"> and workorder_id = #{workorderId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by rt_id desc
    </select>

    <select id="selectWmRtIssueByRtId" parameterType="Long" resultMap="WmRtIssueResult">
