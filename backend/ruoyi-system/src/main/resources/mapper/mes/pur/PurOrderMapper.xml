<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.mes.pur.PurOrderMapper">
    
    <resultMap type="PurOrder" id="PurOrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="factoryId"    column="factory_id"    />
        <result property="orderCode"    column="order_code"    />
        <result property="orderName"    column="order_name"    />
        <result property="vendorId"    column="vendor_id"    />
        <result property="vendorCode"    column="vendor_code"    />
        <result property="vendorName"    column="vendor_name"    />
        <result property="purchaseType"    column="purchase_type"    />
        <result property="orderDate"    column="order_date"    />
        <result property="expectedDate"    column="expected_date"    />
        <result property="purchaser"    column="purchaser"    />
        <result property="approver"    column="approver"    />
        <result property="totalQuantity"    column="total_quantity"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="currency"    column="currency"    />
        <result property="sourceOrderCode"    column="source_order_code"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectPurOrderVo">
        select order_id, factory_id, order_code, order_name, vendor_id, vendor_code, vendor_name, purchase_type, order_date, expected_date, purchaser, approver, total_quantity, total_amount, currency, source_order_code, status, remark, create_by, create_time, update_by, update_time from qxx_pur_order
    </sql>

    <select id="selectPurOrderList" parameterType="PurOrder" resultMap="PurOrderResult">
        <include refid="selectPurOrderVo"/>
        <where>            <if test="orderCode != null  and orderCode != ''"> and order_code = #{orderCode}</if>
            <if test="orderName != null  and orderName != ''"> and order_name like concat('%', #{orderName}, '%')</if>
            <if test="vendorId != null "> and vendor_id = #{vendorId}</if>
            <if test="vendorCode != null  and vendorCode != ''"> and vendor_code = #{vendorCode}</if>
            <if test="vendorName != null  and vendorName != ''"> and vendor_name like concat('%', #{vendorName}, '%')</if>
            <if test="purchaseType != null  and purchaseType != ''"> and purchase_type = #{purchaseType}</if>
            <if test="params.beginOrderDate != null and params.beginOrderDate != ''"> and order_date &gt;= #{params.beginOrderDate}</if>
            <if test="params.endOrderDate != null and params.endOrderDate != ''"> and order_date &lt;= #{params.endOrderDate}</if>
            <if test="params.beginExpectedDate != null and params.beginExpectedDate != ''"> and expected_date &gt;= #{params.beginExpectedDate}</if>
            <if test="params.endExpectedDate != null and params.endExpectedDate != ''"> and expected_date &lt;= #{params.endExpectedDate}</if>
            <if test="purchaser != null  and purchaser != ''"> and purchaser = #{purchaser}</if>
            <if test="approver != null  and approver != ''"> and approver = #{approver}</if>
            <if test="totalQuantity != null "> and total_quantity = #{totalQuantity}</if>
            <if test="totalAmount != null "> and total_amount = #{totalAmount}</if>
            <if test="currency != null  and currency != ''"> and currency = #{currency}</if>
            <if test="sourceOrderCode != null  and sourceOrderCode != ''"> and source_order_code = #{sourceOrderCode}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        ORDER BY create_time DESC
    </select>
    
    <select id="selectPurOrderByOrderId" parameterType="Long" resultMap="PurOrderResult">
        <include refid="selectPurOrderVo"/>
        where order_id = #{orderId}
    </select>

    <insert id="insertPurOrder" parameterType="PurOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into qxx_pur_order
        <trim prefix="(" suffix=")" suffixOverrides=",">            <if test="orderCode != null and orderCode != ''">order_code,</if>
            <if test="orderName != null">order_name,</if>
            <if test="vendorId != null">vendor_id,</if>
            <if test="vendorCode != null">vendor_code,</if>
            <if test="vendorName != null">vendor_name,</if>
            <if test="purchaseType != null">purchase_type,</if>
            <if test="orderDate != null">order_date,</if>
            <if test="expectedDate != null">expected_date,</if>
            <if test="purchaser != null">purchaser,</if>
            <if test="approver != null">approver,</if>
            <if test="totalQuantity != null">total_quantity,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="currency != null">currency,</if>
            <if test="sourceOrderCode != null">source_order_code,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">            <if test="orderCode != null and orderCode != ''">#{orderCode},</if>
            <if test="orderName != null">#{orderName},</if>
            <if test="vendorId != null">#{vendorId},</if>
            <if test="vendorCode != null">#{vendorCode},</if>
            <if test="vendorName != null">#{vendorName},</if>
            <if test="purchaseType != null">#{purchaseType},</if>
            <if test="orderDate != null">#{orderDate},</if>
            <if test="expectedDate != null">#{expectedDate},</if>
            <if test="purchaser != null">#{purchaser},</if>
            <if test="approver != null">#{approver},</if>
            <if test="totalQuantity != null">#{totalQuantity},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="currency != null">#{currency},</if>
            <if test="sourceOrderCode != null">#{sourceOrderCode},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>         </trim>
    </insert>

    <update id="updatePurOrder" parameterType="PurOrder">
        update qxx_pur_order
        <trim prefix="SET" suffixOverrides=",">            <if test="orderCode != null and orderCode != ''">order_code = #{orderCode},</if>
            <if test="orderName != null">order_name = #{orderName},</if>
            <if test="vendorId != null">vendor_id = #{vendorId},</if>
            <if test="vendorCode != null">vendor_code = #{vendorCode},</if>
            <if test="vendorName != null">vendor_name = #{vendorName},</if>
            <if test="purchaseType != null">purchase_type = #{purchaseType},</if>
            <if test="orderDate != null">order_date = #{orderDate},</if>
            <if test="expectedDate != null">expected_date = #{expectedDate},</if>
            <if test="purchaser != null">purchaser = #{purchaser},</if>
            <if test="approver != null">approver = #{approver},</if>
            <if test="totalQuantity != null">total_quantity = #{totalQuantity},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="currency != null">currency = #{currency},</if>
            <if test="sourceOrderCode != null">source_order_code = #{sourceOrderCode},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deletePurOrderByOrderId" parameterType="Long">
        delete from qxx_pur_order where order_id = #{orderId}
    </delete>

    <delete id="deletePurOrderByOrderIds" >
        delete from qxx_pur_order where order_id in 
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>