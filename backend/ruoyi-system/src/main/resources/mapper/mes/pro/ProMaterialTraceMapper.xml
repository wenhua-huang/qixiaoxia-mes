            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="traceType != null and traceType != ''">#{traceType},</if>
            <if test="parentType != null and parentType != ''">#{parentType},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="childType != null and childType != ''">#{childType},</if>
            <if test="childId != null">#{childId},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''">#{unitOfMeasure},</if>
