    <delete id="deleteWmIssueHeaderByIssueId" parameterType="Long">
        delete from qxx_wm_issue_header where issue_id = #{issueId}
    </delete>

    <delete id="deleteWmIssueHeaderByIssueIds">
        delete from qxx_wm_issue_header where issue_id in
        <foreach item="issueId" collection="array" open="(" separator="," close=")">
            #{issueId}
        </foreach>
    </delete>
