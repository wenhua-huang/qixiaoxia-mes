<mapper namespace="com.ruoyi.system.mapper.mes.wm.WmBarcodeMapper">

    <resultMap type="WmBarcode" id="WmBarcodeResult">
        <id property="barcodeId" column="barcode_id" />
        <result property="factoryId" column="factory_id" />
        <result property="barcodeCode" column="barcode_code" />
        <result property="barcodeType" column="barcode_type" />
        <result property="itemId" column="item_id" />
        <result property="itemCode" column="item_code" />
        <result property="itemName" column="item_name" />
        <result property="workorderId" column="workorder_id" />
        <result property="workorderCode" column="workorder_code" />
        <result property="quantity" column="quantity" />
        <result property="unitOfMeasure" column="unit_of_measure" />
        <result property="batchCode" column="batch_code" />
        <result property="printCount" column="print_count" />
        <result property="lastPrintTime" column="last_print_time" />
