    <select id="selectWmPackageList" parameterType="WmPackage" resultMap="WmPackageResult">
        <include refid="selectWmPackageVo"/>
        <where>
            <if test="factoryId != null"> and factory_id = #{factoryId}</if>
            <if test="packageCode != null and packageCode != ''"> and package_code like concat('%', #{packageCode}, '%')</if>
            <if test="packageName != null and packageName != ''"> and package_name like concat('%', #{packageName}, '%')</if>
            <if test="parentId != null"> and parent_id = #{parentId}</if>
