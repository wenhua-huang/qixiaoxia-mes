    <sql id="selectProMaterialTraceVo">
        select trace_id, factory_id, trace_type, parent_type, parent_id, child_type, child_id, quantity, unit_of_measure, workorder_id, card_id, card_process_id, issue_id, issue_detail_id, feedback_id, transaction_id, process_id, trace_time, remark, create_by, create_time, update_by, update_time from qxx_pro_material_trace
    </sql>

    <select id="selectProMaterialTraceList" parameterType="ProMaterialTrace" resultMap="ProMaterialTraceResult">
        <include refid="selectProMaterialTraceVo"/>
        <where>
            <if test="traceType != null  and traceType != ''"> and trace_type = #{traceType}</if>
            <if test="workorderId != null"> and workorder_id = #{workorderId}</if>
            <if test="cardId != null"> and card_id = #{cardId}</if>
            <if test="processId != null"> and process_id = #{processId}</if>
        </where>
        order by trace_id desc
    </select>

    <select id="selectProMaterialTraceByTraceId" parameterType="Long" resultMap="ProMaterialTraceResult">
        <include refid="selectProMaterialTraceVo"/>
        where trace_id = #{traceId}
    </select>

    <insert id="insertProMaterialTrace" parameterType="ProMaterialTrace" useGeneratedKeys="true" keyProperty="traceId">
        insert into qxx_pro_material_trace
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="traceType != null and traceType != ''">trace_type,</if>
            <if test="parentType != null and parentType != ''">parent_type,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="childType != null and childType != ''">child_type,</if>
