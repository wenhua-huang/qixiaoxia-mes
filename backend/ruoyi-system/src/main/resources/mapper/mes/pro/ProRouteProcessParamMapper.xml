<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.mes.pro.ProRouteProcessParamMapper">

    <resultMap type="ProRouteProcessParam" id="ProRouteProcessParamResult">
        <result property="recordId"    column="record_id"    />
        <result property="factoryId"    column="factory_id"    />
        <result property="routeProductId"    column="route_product_id"    />
        <result property="processId"    column="process_id"    />
        <result property="templateId"    column="template_id"    />
        <result property="paramValue"    column="param_value"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectProRouteProcessParamVo">
        select record_id, factory_id, route_product_id, process_id, template_id, param_value, remark, create_by, create_time, update_by, update_time from qxx_pro_route_process_param
    </sql>

    <select id="selectProRouteProcessParamList" parameterType="ProRouteProcessParam" resultMap="ProRouteProcessParamResult">
        <include refid="selectProRouteProcessParamVo"/>
        <where>
            <if test="routeProductId != null "> and route_product_id = #{routeProductId}</if>
            <if test="processId != null "> and process_id = #{processId}</if>
        </where>
        order by record_id asc
    </select>

    <select id="selectProRouteProcessParamByRecordId" parameterType="Long" resultMap="ProRouteProcessParamResult">
        <include refid="selectProRouteProcessParamVo"/>
        where record_id = #{recordId}
    </select>

    <select id="selectProRouteProcessParamByRouteProductId" parameterType="Long" resultMap="ProRouteProcessParamResult">
        <include refid="selectProRouteProcessParamVo"/>
        where route_product_id = #{routeProductId}
        order by record_id asc
    </select>

    <insert id="insertProRouteProcessParam" parameterType="ProRouteProcessParam" useGeneratedKeys="true" keyProperty="recordId">
        insert into qxx_pro_route_process_param
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="routeProductId != null">route_product_id,</if>
            <if test="processId != null">process_id,</if>
            <if test="templateId != null">template_id,</if>
            <if test="paramValue != null">param_value,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="routeProductId != null">#{routeProductId},</if>
            <if test="processId != null">#{processId},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="paramValue != null">#{paramValue},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateProRouteProcessParam" parameterType="ProRouteProcessParam">
        update qxx_pro_route_process_param
        <trim prefix="SET" suffixOverrides=",">
            <if test="routeProductId != null">route_product_id = #{routeProductId},</if>
            <if test="processId != null">process_id = #{processId},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="paramValue != null">param_value = #{paramValue},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteProRouteProcessParamByRecordId" parameterType="Long">
        delete from qxx_pro_route_process_param where record_id = #{recordId}
    </delete>

    <delete id="deleteProRouteProcessParamByRecordIds">
        delete from qxx_pro_route_process_param where record_id in
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>

    <delete id="deleteProRouteProcessParamByRouteProductId" parameterType="Long">
        delete from qxx_pro_route_process_param where route_product_id = #{routeProductId}
    </delete>
</mapper>
