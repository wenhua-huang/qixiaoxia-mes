            <if test="areaId != null">#{areaId},</if>
            <if test="areaCode != null and areaCode != ''">#{areaCode},</if>
            <if test="areaName != null and areaName != ''">#{areaName},</if>
            <if test="issueDate != null">#{issueDate},</if>
            <if test="quantityTotal != null">#{quantityTotal},</if>
            <if test="quantityIssuedTotal != null">#{quantityIssuedTotal},</if>
            <if test="quantityReceived != null">#{quantityReceived},</if>
            <if test="version != null">#{version},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="approveBy != null">#{approveBy},</if>
            <if test="approveTime != null">#{approveTime},</if>
            <if test="cancelReason != null">#{cancelReason},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

